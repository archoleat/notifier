{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "composite": true,
    "emitDeclarationOnly": true,
    "lib": ["DOM", "ESNext"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "target": "ESNext",
    "types": ["node", "vitest"]
  }
}
